# ─── APP ─────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://scsplatform.com
MOBILE_URL=

# ─── DATABASE ────────────────────────────────────────────
DATABASE_URL=postgresql://scs_user:CHANGE_THIS_PASSWORD@postgres:5432/scs_platform
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# ─── REDIS ───────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASS@redis:6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASS

# ─── JWT (generate strong secrets: openssl rand -base64 64) ─
JWT_ACCESS_SECRET=CHANGE_THIS_ACCESS_SECRET_MINIMUM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MINIMUM_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── AI APIs ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ─── PAYMENTS ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AWS S3 (file uploads) ───────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=scs-platform

# ─── EMAIL ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@scsplatform.com
SMTP_PASS=
EMAIL_FROM=SCS Platform <noreply@scsplatform.com>

# ─── FRONTEND ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://scsplatform.com/api
NEXT_PUBLIC_WS_URL=https://scsplatform.com
