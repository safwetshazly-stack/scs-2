# ═══════════════════════════════════════════════════════════════════════════════
# SCS Platform - Comprehensive Environment Configuration Guide
# ═══════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT:
# 1. Copy this file to .env in the root directory
# 2. Fill in all values according to your environment (dev/staging/production)
# 3. Keep .env.example in version control (for team reference)
# 4. NEVER commit your actual .env file (add to .gitignore)
# 5. Use strong, random values for all secrets in production
#
# SECURITY NOTE: Treat passwords and API keys as sensitive information.
# Rotate them regularly in production environments.

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 APPLICATION CORE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Environment type: development | staging | production
NODE_ENV=production

# Application server port
PORT=4000

# ─────────────────────────────────────────────────────────────────────────────
# 💾 DATABASE CONFIGURATION (PostgreSQL 16+)
# ─────────────────────────────────────────────────────────────────────────────
#
# Format: postgresql://[username]:[password]@[host]:[port]/[database]
# Example: postgresql://scs_user:mysecurepass@db.example.com:5432/scs_platform
#
# PRODUCTION TIP: Use a managed database service (AWS RDS, Railway, Vercel Postgres)
# SECURITY TIP: Never use default passwords in production

DATABASE_URL=postgresql://scs_user:CHANGE_THIS_PASSWORD@postgres:5432/scs_platform
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# ─────────────────────────────────────────────────────────────────────────────
# 🔴 REDIS CACHE & SESSION STORE (Redis 7+)
# ─────────────────────────────────────────────────────────────────────────────
#
# Used for:
# - Caching search results and common queries
# - Session token blacklisting
# - Real-time notifications
# - Rate limiting
#
# Format: redis://[password]@[host]:[port]
# Cluster: redis+cluster://host1:6379,host2:6379

REDIS_URL=redis://:CHANGE_THIS_REDIS_PASS@redis:6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASS

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 JWT AUTHENTICATION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
#
# Generate strong secrets using: openssl rand -base64 64
#
# Access Token: Short-lived, used for each request (15m default)
# Refresh Token: Long-lived, used to get new access token (30d default)
#
# TOKEN STRATEGY:
# - Access token is sent in Authorization header
# - Refresh token is stored securely in HTTP-only cookie
# - Both tokens are signed with unique secrets for extra security

JWT_ACCESS_SECRET=CHANGE_THIS_ACCESS_SECRET_MINIMUM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MINIMUM_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 FRONTEND & MOBILE CLIENT URLS
# ─────────────────────────────────────────────────────────────────────────────
#
# Used for:
# - CORS policy configuration
# - Email verification links
# - Password reset links
# - OAuth redirect URIs
#
# DEVELOPMENT: http://localhost:3000
# PRODUCTION: https://yourdomain.com (with trailing slash)

FRONTEND_URL=https://scsplatform.com
MOBILE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 AI SERVICES INTEGRATION
# ─────────────────────────────────────────────────────────────────────────────
#
# OPTIONAL: Configure at least ONE AI provider for AI chat features
# If none are configured, AI features will be disabled gracefully
#
# FEATURES ENABLED PER PROVIDER:
# - OpenAI GPT-4/3.5: Full chat, image generation, embeddings
# - Anthropic Claude 3: Chat, long-context support, code analysis
# - DeepSeek: Cost-effective alternative, similar to GPT-3.5
#
# GET API KEYS:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/keys
# - DeepSeek: https://platform.deepseek.com/keys
#
# COST ESTIMATE (Monthly):
# - OpenAI GPT-4: ~$20-50 per 1M users
# - Claude 3: ~$15-40 per 1M users
# - DeepSeek: ~$3-10 per 1M users

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# 💳 STRIPE PAYMENT PROCESSING
# ─────────────────────────────────────────────────────────────────────────────
#
# Enables course purchases and premium features
#
# SETUP INSTRUCTIONS:
# 1. Create Stripe account: https://dashboard.stripe.com/register
# 2. Get API keys: https://dashboard.stripe.com/apikeys
# 3. Set up webhook: https://dashboard.stripe.com/webhooks
#    - Endpoint: https://yourdomain.com/api/payment/webhook
#    - Events: payment_intent.setup_succeeded, payment_intent.payment_failed,
#              charge.refunded, customer.subscription.deleted
#
# KEYS DIFFERENCE:
# - Test keys (sk_test_): For development/staging
# - Live keys (sk_live_): For production only
#
# WEBHOOK SECRET:
# - Get from Webhook settings page after creating endpoint
# - Used to verify webhook authenticity

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# 📁 AWS S3 FILE STORAGE (For course videos, documents, avatars)
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS:
# 1. Create AWS account: https://aws.amazon.com
# 2. Create S3 bucket: https://s3.console.aws.amazon.com/s3
# 3. Create IAM user with S3 permissions
# 4. Configure bucket CORS settings (allow PUT from your frontend URL)
#
# CORS CONFIGURATION EXAMPLE:
# [
#   {
#     "AllowedMethods": ["GET", "PUT", "POST"],
#     "AllowedOrigins": ["https://yourdomain.com"],
#     "AllowedHeaders": ["*"],
#     "ExposeHeaders": ["ETag"]
#   }
# ]
#
# FOLDER STRUCTURE IN S3:
# - scs-platform/courses/{courseId}/videos/
# - scs-platform/courses/{courseId}/documents/
# - scs-platform/users/{userId}/avatar/
# - scs-platform/users/{userId}/cover-image/
#
# STORAGE ESTIMATE:
# - 100 courses with videos: ~5-10 TB
# - 1M users with avatars: ~50-100 GB
# Monthly cost: ~$100-500 depending on region

AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_BUCKET=scs-platform

# ─────────────────────────────────────────────────────────────────────────────
# 📧 SMTP EMAIL SERVICE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
#
# For sending:
# - Verification emails
# - Password reset emails
# - Welcome emails
# - Course enrollment confirmations
#
# RECOMMENDED PROVIDERS:
# - Gmail: Free tier with App Password (~5k/day limit)
# - SendGrid: Reliable, good support (~100 free/day)
# - AWS SES: Cheap, high volume (~14 cents per 1k)
# - Mailgun: Developer-friendly (~1k free/month)
#
# GMAIL SETUP:
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use app-specific password in SMTP_PASS
#
# SENDGRID SETUP:
# 1. Create account and verify email
# 2. Get API key from Settings
# 3. Use "apikey" as username and key as password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@scsplatform.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=SCS Platform <noreply@scsplatform.com>

# ─────────────────────────────────────────────────────────────────────────────
# 🎨 FRONTEND CONFIGURATION (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
#
# These are used in the frontend application for API calls

NEXT_PUBLIC_API_URL=https://scsplatform.com/api
NEXT_PUBLIC_WS_URL=https://scsplatform.com

# ═══════════════════════════════════════════════════════════════════════════════
# 📋 QUICK START CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# DEVELOPMENT SETUP:
# [ ] Copy this file to .env
# [ ] Use local PostgreSQL and Redis (Docker or local installation)
# [ ] Leave AI keys empty (AI features will be disabled)
# [ ] Leave Stripe keys as test keys (sk_test_*)
# [ ] Use local file storage or development S3 bucket
#
# STAGING SETUP:
# [ ] All secrets must be strong (>32 characters)
# [ ] Use staging database and Redis
# [ ] Use Stripe test keys (sk_test_*)
# [ ] Configure one AI provider for testing
# [ ] Use separate S3 bucket for staging
#
# PRODUCTION SETUP:
# [ ] All secrets must be EXTREMELY strong (>64 characters, random)
# [ ] Use production database with RDS/managed service
# [ ] Use production Redis (ElastiCache/managed service)
# [ ] Use Stripe live keys (sk_live_*) - CAREFUL!
# [ ] Configure at least 2 AI providers for redundancy
# [ ] Use production S3 bucket with proper encryption
# [ ] Enable CloudFront CDN for S3 content
# [ ] Use managed email service (SendGrid/AWS SES)
# [ ] Enable database daily backups and encryption
# [ ] Set up CloudWatch alarms for all critical metrics
#
# ═══════════════════════════════════════════════════════════════════════════════
